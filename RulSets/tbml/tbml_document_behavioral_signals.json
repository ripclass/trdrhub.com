[
    {
        "rule_id":  "TBML-DOC-001",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Document amendment burst before presentation",
        "description":  "Excessive last-minute edits across docs are suspicious.",
        "severity":  "warn",
        "conditions":  [
                           {
                               "field":  "docs.amendments_last_72h",
                               "type":  "numeric_range",
                               "max":  2
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "Amendment activity is within operational norm."
                                           ],
                                 "invalid":  [
                                                 "Amendment burst detected within 72h of presentation."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-DOC-002",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Repeated OCR confidence suppression pattern",
        "description":  "Consistently low OCR confidence in critical fields may indicate tampering.",
        "severity":  "warn",
        "conditions":  [
                           {
                               "field":  "docs.low_confidence_critical_field_count",
                               "type":  "numeric_range",
                               "max":  1
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "OCR confidence profile appears normal."
                                           ],
                                 "invalid":  [
                                                 "Multiple critical fields with low OCR confidence."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
