[
    {
        "rule_id":  "TBML-PRC-001",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Invoice unit price spike vs 90-day baseline",
        "description":  "Flag if unit price materially exceeds historical baseline for same buyer-seller-HS tuple.",
        "severity":  "fail",
        "conditions":  [
                           {
                               "field":  "invoice.unit_price_vs_baseline_ratio",
                               "type":  "numeric_range",
                               "max":  1.35
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "Unit price is within approved variance band."
                                           ],
                                 "invalid":  [
                                                 "Unit price exceeds 35% of baseline variance threshold."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-PRC-002",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Invoice unit price drop anomaly",
        "description":  "Flag potential under-invoicing when price is far below expected range.",
        "severity":  "warn",
        "conditions":  [
                           {
                               "field":  "invoice.unit_price_vs_baseline_ratio",
                               "min":  0.7,
                               "type":  "numeric_range"
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "Unit price not materially below baseline."
                                           ],
                                 "invalid":  [
                                                 "Unit price is 30%+ below baseline (under-invoicing signal)."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-PRC-003",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Invoice vs purchase order unit price mismatch",
        "description":  "Unit price on commercial invoice should align with PO line item.",
        "severity":  "fail",
        "conditions":  [
                           {
                               "field":  "invoice.unit_price",
                               "tolerance_pct":  5,
                               "compare_to":  "purchase_order.unit_price",
                               "type":  "consistency_check"
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "Invoice and PO unit prices are aligned."
                                           ],
                                 "invalid":  [
                                                 "Invoice unit price diverges from PO beyond 5%."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-PRC-004",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Invoice total vs contract value overrun",
        "description":  "Total invoice value must not exceed contract value unless amendment exists.",
        "severity":  "fail",
        "conditions":  [
                           {
                               "field":  "invoice.total_amount_vs_contract_ratio",
                               "type":  "numeric_range",
                               "max":  1.05
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "Invoice value is within contract tolerance."
                                           ],
                                 "invalid":  [
                                                 "Invoice value exceeds contract by more than 5%."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-PRC-005",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Repeated round-number pricing pattern",
        "description":  "Detect repetitive round-number unit pricing often associated with synthetic invoicing.",
        "severity":  "warn",
        "conditions":  [
                           {
                               "field":  "invoice.round_number_line_ratio",
                               "type":  "numeric_range",
                               "max":  0.8
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "Round-number pricing ratio is within normal pattern."
                                           ],
                                 "invalid":  [
                                                 "Excessive round-number pricing concentration detected."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-PRC-006",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Unusual discount depth by corridor",
        "description":  "Discount beyond corridor norm is flagged for trade-based laundering pattern.",
        "severity":  "warn",
        "conditions":  [
                           {
                               "field":  "invoice.discount_pct",
                               "type":  "numeric_range",
                               "max":  25
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "Discount level appears commercially plausible."
                                           ],
                                 "invalid":  [
                                                 "Discount exceeds 25% and breaches corridor norm."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-PRC-007",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Currency conversion spread anomaly",
        "description":  "FX-implied converted value should remain within approved spread.",
        "severity":  "warn",
        "conditions":  [
                           {
                               "field":  "invoice.fx_spread_bps",
                               "type":  "numeric_range",
                               "max":  350
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "FX spread is within accepted band."
                                           ],
                                 "invalid":  [
                                                 "FX spread exceeds 350 bps and needs review."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-PRC-008",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Price inconsistency across same shipment lines",
        "description":  "Identical SKU lines in same shipment should not show unexplained price variance.",
        "severity":  "warn",
        "conditions":  [
                           {
                               "field":  "invoice.same_sku_price_variance_pct",
                               "type":  "numeric_range",
                               "max":  12
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "Same-SKU pricing variance is acceptable."
                                           ],
                                 "invalid":  [
                                                 "Same-SKU pricing variance exceeds 12% without justification."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    }
]
