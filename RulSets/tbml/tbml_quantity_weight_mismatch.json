    },
    {
        "rule_id":  "TBML-QTY-007",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "UOM mismatch across key docs",
        "description":  "Unit of measure should remain consistent across invoice, PO, and packing list.",
