        "expected_outcome":  {
                                 "valid":  [
                                               "Net-to-gross ratio is plausible."
                                           ],
                                 "invalid":  [
                                                 "Net-to-gross ratio outside expected limits."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-QTY-006",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Quantity split pattern across invoices",
