        "expected_outcome":  {
                                 "valid":  [
                                               "Declared weight within container capacity."
                                           ],
                                 "invalid":  [
                                                 "Declared weight exceeds container capacity."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-QTY-005",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Net-to-gross weight ratio anomaly",
        "description":  "Net/gross ratio outside normal range indicates potential manipulation.",
        "severity":  "warn",
        "conditions":  [
                           {
                               "field":  "shipment.net_to_gross_ratio",
