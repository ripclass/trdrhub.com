[
    {
        "rule_id":  "TBML-QTY-001",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Invoice quantity exceeds LC tolerance",
        "description":  "Invoice quantity must be inside LC tolerance band.",
        "severity":  "fail",
        "conditions":  [
                           {
                               "field":  "invoice.quantity_vs_lc_ratio",
                               "min":  0.95,
                               "type":  "numeric_range",
                               "max":  1.05
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "Invoice quantity is within LC tolerance."
                                           ],
                                 "invalid":  [
                                                 "Invoice quantity breaches LC tolerance band."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-QTY-002",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Bill of lading weight vs packing list mismatch",
        "description":  "Gross/net weights should reconcile between B/L and packing list.",
        "severity":  "fail",
        "conditions":  [
                           {
                               "field":  "bl.gross_weight",
                               "tolerance_pct":  3,
                               "compare_to":  "packing_list.gross_weight",
                               "type":  "consistency_check"
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "Weight values reconcile across B/L and packing list."
                                           ],
                                 "invalid":  [
                                                 "Weight mismatch above 3% across transport and packing docs."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-QTY-003",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Per-unit declared weight anomaly",
        "description":  "Declared weight per unit should remain in expected commodity range.",
        "severity":  "warn",
        "conditions":  [
                           {
                               "field":  "shipment.weight_per_unit_vs_historical_ratio",
                               "min":  0.8,
                               "type":  "numeric_range",
                               "max":  1.25
                           }
                       ],
        "expected_outcome":  {
                                 "valid":  [
                                               "Per-unit weight is within expected range."
                                           ],
                                 "invalid":  [
                                                 "Per-unit weight outside expected commodity bounds."
                                             ]
                             },
        "deterministic":  true,
        "requires_llm":  false
    },
    {
        "rule_id":  "TBML-QTY-004",
        "domain":  "tbml.v1",
        "jurisdiction":  "global",
        "title":  "Container capacity breach check",
        "description":  "Declared cargo weight should not exceed container legal/physical capacity.",
        "severity":  "fail",
        "conditions":  [
                           {
                               "field":  "shipment.container_load_ratio",
