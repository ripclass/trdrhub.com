# LCopilot API Production Environment Configuration
# Copy to apps/api/.env.production and provide real secrets.

ENVIRONMENT=production
DEBUG=false
API_BASE_URL=https://api.trdrhub.com
FRONTEND_URL=https://app.trdrhub.com

# Database
DATABASE_URL=postgresql://username:password@db-host:5432/lcopilot_prod

# Authentication (change immediately in production)
SECRET_KEY=replace-with-production-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_SECRET_KEY=replace-with-production-jwt-secret
JWT_EXPIRATION_HOURS=24

# AWS (required when USE_STUBS=false)
USE_STUBS=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
S3_BUCKET_NAME=lcopilot-prod-documents
DR_OBJECT_BACKUP_BUCKET=trdrhub-prod-backups

# Google Document AI
GOOGLE_CLOUD_PROJECT=prod-gcp-project
GOOGLE_DOCUMENTAI_LOCATION=us
GOOGLE_DOCUMENTAI_PROCESSOR_ID=processor-id
GOOGLE_APPLICATION_CREDENTIALS=/workspace/keys/google-documentai.json

# AI Providers
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_VERSION=openai/gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL_VERSION=gpt-4o

# Billing Providers
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=false

# Observability
LOG_LEVEL=INFO
CLOUDWATCH_NAMESPACE=lcopilot-prod
